"""Consilium Providers — все 26 провайдеров из FreeLLMAPI.
Каждый провайдер: name, base_url, key_prefix, models, format, keyless, enabled.
Если в .env нет ключей — enabled=False. Если ключ начинается с 'proxy:' — идёт через прокси."""
import os
from pathlib import Path
from dotenv import load_dotenv

# Загружаем .env из домашней директории
load_dotenv(Path.home() / ".hermes" / ".env")

def _load_keys(prefix: str) -> list[str]:
    """Загружает ключи PREFIX_1, PREFIX_2, PREFIX_3 из окружения."""
    keys = []
    for i in range(1, 4):
        k = os.getenv(f"{prefix}_{i}", "").strip()
        if k:
            keys.append(k)
    return keys

def _provider_enabled(keys: list[str], keyless: bool) -> bool:
    """Провайдер включён, если есть ключи или он keyless."""
    return keyless or bool(keys)

