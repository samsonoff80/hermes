# Собираем итоговый список с загрузкой ключей и флагом enabled
PROVIDERS = []
for p in RAW_PROVIDERS:
    keys = _load_keys(p["key_prefix"])
    enabled = _provider_enabled(keys, p["keyless"])
    PROVIDERS.append({
        **p,
        "keys": keys,
        "enabled": enabled,
        "key_index": 0,  # для round-robin
        "cooldown_until": 0.0,  # для 429
    })

# Экспорт для удобства
__all__ = ["PROVIDERS", "RAW_PROVIDERS"]
