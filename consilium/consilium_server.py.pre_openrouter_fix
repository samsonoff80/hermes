def get_cooldown_time(provider_name: str, status_code: int, retry_after: Optional[int] = None) -> int:
    limits = PROVIDER_LIMITS.get(provider_name, {})
    if retry_after:
        return min(retry_after, 300)
    if status_code == 429:
        return limits.get("cooldown_429", 60)
    if status_code in (401, 403):
        return 86400  # 24 часа
    return 30

class CooldownManager:
    """Управляет временным отстранением провайдеров"""
    def __init__(self):
        self.cooldowns: Dict[str, datetime] = {}
    
    def set(self, name: str, seconds: int = 30):
        self.cooldowns[name] = datetime.now() + timedelta(seconds=seconds)
        logger.info(f"⏳ {name} cooldown {seconds}s")
    
    def set_429(self, name: str, retry_after: int = 60):
        # Нарастающий cooldown: 60 → 300 → 900 → 3600 секунд
        if not hasattr(self, '_429_count'):
            self._429_count = {}
        count = self._429_count.get(name, 0) + 1
        self._429_count[name] = count
        # 1-я: 60с, 2-я: 5мин, 3-я: 15мин, 4+: 1час
        delays = {1: 60, 2: 300, 3: 900}
        seconds = delays.get(count, 3600)
        self.set(name, seconds)
    
    def reset_429(self, name: str):
        if hasattr(self, '_429_count'):
            self._429_count[name] = 0
    
    def is_cooling(self, name: str) -> bool:
        if name not in self.cooldowns:
            return False
        if datetime.now() < self.cooldowns[name]:
            return True
        del self.cooldowns[name]
        return False

