def get_next_key(provider_name: str):
    keys = PROVIDER_KEYS.get(provider_name, [])
    if not keys:
        return os.getenv(provider_name.upper() + "_API_KEY", "")
    idx = key_indexes[provider_name] % len(keys)
    key_indexes[provider_name] += 1
    return keys[idx]


