def cache_key(model: str, messages: List[Dict]) -> str:
    raw = json.dumps({"model": model, "messages": messages}, sort_keys=True, ensure_ascii=False)
    return hashlib.sha256(raw.encode()).hexdigest()

def estimate_tokens(messages: List[Dict]) -> int:
    total = 0
    for m in messages:
        text = str(m.get("content", ""))
        if not text: continue
        cyrillic = sum(1 for c in text if ('а' <= c.lower() <= 'я') or c.lower() == 'ё')
        ratio = 2 if cyrillic > len(text) * 0.3 else 4
        total += len(text) // ratio
    return total

async def call_openai(provider: Dict, messages: List[Dict], model: str, stream: bool = False, temperature: float = 0.7, max_tokens: Optional[int] = None):
    url = f"{provider['base_url'].rstrip('/')}/chat/completions"
    
    api_key = get_next_key(provider["name"])
    if not api_key:
        raise ValueError(f"No keys for {provider['name']}")
    
    headers = {"Content-Type": "application/json", "Authorization": f"Bearer {api_key}"}
    if provider["name"] == "openrouter":
        headers["HTTP-Referer"] = "https://github.com/Fireglow1980/hermes-pipeline"
        headers["X-Title"] = "Consilium"
    
    payload = {"model": model, "messages": messages, "stream": stream, "temperature": temperature}
    if max_tokens: payload["max_tokens"] = max_tokens
    
    resp = await http_client.post(url, headers=headers, json=payload)
    return resp

async def call_cloudflare(provider: Dict, messages: List[Dict], model: str):
    key_data = get_next_key(provider["name"])
    if isinstance(key_data, tuple):
        api_key, account_id = key_data
    else:
        api_key, account_id = key_data, os.getenv("CLOUDFLARE_ACCOUNT_ID_1", "")
    if not account_id: raise ValueError("CLOUDFLARE_ACCOUNT_ID not set")
    if not api_key: raise ValueError(f"No Cloudflare key")
    
    url = f"{provider['base_url'].replace('{ACCOUNT_ID}', account_id)}/{model}"
    headers = {"Authorization": f"Bearer {api_key}", "Content-Type": "application/json"}
    
    resp = await http_client.post(url, headers=headers, json={"messages": messages})
    if resp.status_code == 200:
        try:
            data = resp.json()
            cf = data.get("result", {}).get("response", "")
            if cf:
                est = estimate_tokens(messages)
                return {
                    "id": f"cf_{int(time.time())}", "object": "chat.completion", "created": int(time.time()),
                    "model": model, "choices": [{"index": 0, "message": {"role": "assistant", "content": cf}, "finish_reason": "stop"}],
                    "usage": {"prompt_tokens": est, "completion_tokens": len(cf)//4, "total_tokens": est + len(cf)//4}
                }
        except Exception:
            logger.warning(f"⚠️ Cloudflare: bad JSON, raw: {resp.text[:100]}")
            return "error"
    return resp

