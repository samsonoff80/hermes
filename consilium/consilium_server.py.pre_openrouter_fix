@app.post("/v1/chat/completions")
async def chat(request: Request):
    try: body = await request.json()
    except: raise HTTPException(400, "Invalid JSON")
    
    model = body.get("model") or "auto"
    messages = body.get("messages", [])
    stream = body.get("stream", False)
    temperature = body.get("temperature", 0.7)
    max_tokens = body.get("max_tokens")
    
    if not messages: raise HTTPException(400, "Messages required")
    est = estimate_tokens(messages)
    
    # Кэш
    key = None
    if not stream and model not in ("auto",):
        key = cache_key(model, messages)
        cached = _cache_get(key)
        if cached:
            metrics["cache_hits"] += 1
            return JSONResponse(content=cached)
    
    # AUTO MODE — правильный fallback
    if model == "auto":
        last_error = None
        
        for p in PROVIDERS:
            if cooldown.is_cooling(p["name"]):
                continue
            if est > p.get("context_window", 100000):
                logger.info(f"⏭️ {p['name']}: context {est} > window {p['context_window']}")
                continue
            
            # Перебираем модели внутри провайдера
            for model_name in p["models"]:
                try:
                    if p["format"] == "cloudflare":
                        r = await call_cloudflare(p, messages, model_name)
                    else:
                        r = await call_openai(p, messages, model_name, stream, temperature, max_tokens)
                    
                    if isinstance(r, httpx.Response):
                        if r.status_code == 200:
                            metrics["requests"] += 1
                            metrics["provider_usage"][p["name"]] += 1
                            logger.info(f"✅ {p['name']}/{model_name} 200 OK")
                            # Проверяем Content-Type
                            ct = r.headers.get("content-type", "")
                            if "html" in ct.lower():
                                logger.warning(f"⚠️ {p['name']}/{model_name}: Got HTML instead of JSON")
                                continue
                            try:
                                data = r.json()
                            except Exception:
                                text = r.text[:500] if r.text else 'empty response'
                                logger.error(f"❌ {p['name']}/{model_name}: bad JSON: {text}")
                                continue
                            if key: _cache_set(key, data)
                            return JSONResponse(content=data)
                        
                        elif r.status_code == 429:
                            retry_after = int(r.headers.get("Retry-After", 60))
                            last_error = f"{p['name']}/{model_name}: 429 → next key"
                            continue  # Следующая модель/ключ этого же провайдера
                        
                        elif r.status_code in (401, 403):
                            cooldown.set(p["name"], get_cooldown_time(p["name"], r.status_code))
                            last_error = f"{p['name']}: {r.status_code} → cooldown 24h"
                            break
                        
                        else:
                            last_error = f"{p['name']}: HTTP {r.status_code}"
                            continue  # Следующая модель
                    
                    elif isinstance(r, dict):
                        metrics["requests"] += 1
                        metrics["provider_usage"][p["name"]] += 1
                        if key: _cache_set(key, r)
                        return JSONResponse(content=r)
                
                except Exception as e:
                    logger.error(f"❌ {p['name']}/{model_name}: {e}")
                    last_error = f"{p['name']}: {str(e)[:100]}"
                    continue
            
            # Если дошли сюда — ни одна модель провайдера не сработала
            continue
        
        raise HTTPException(503, f"All providers failed. Last: {last_error}")
    
    # Конкретный провайдер
    if "/" in model:
        pn, mn = model.split("/", 1)
        for p in PROVIDERS:
            if p["name"] != pn: continue
            if cooldown.is_cooling(pn):
                raise HTTPException(503, f"{pn} on cooldown")
            
            try:
                if p["format"] == "cloudflare":
                    r = await call_cloudflare(p, messages, mn)
                else:
                    r = await call_openai(p, messages, mn, stream, temperature, max_tokens)
                
                if isinstance(r, httpx.Response):
                    if r.status_code == 200:
                        try:
                            data = r.json()
                        except Exception:
                            text = r.text[:500] if r.text else 'empty response'
                            raise HTTPException(502, f"Bad JSON from {pn}: {text}")
                        if key: _cache_set(key, data)
                    return JSONResponse(content=data)
                    raise HTTPException(r.status_code, r.text[:500])
                return JSONResponse(content=r)
            except HTTPException:
                raise
            except Exception as e:
                raise HTTPException(500, str(e)[:200])
        raise HTTPException(404, f"Provider {pn} not found")
    
    raise HTTPException(400, f"Unknown model: {model}")

